#!/usr/bin/env bash
set -euo pipefail

env_file="$HOME/Dominion/secrets/mt5.env"
if [ -f "$env_file" ]; then
  set -a
  # shellcheck disable=SC1090
  source "$env_file"
  set +a
fi

export WINEPREFIX="${DOMDATA_WINEPREFIX:-$HOME/.mt5}"

pkill -f '[t]erminal64.exe' 2>/dev/null || true
pkill -f '[Mm]eta[Tt]rader' 2>/dev/null || true
wineserver -k >/dev/null 2>&1 || true

echo "MT5/Wine stop requested"
